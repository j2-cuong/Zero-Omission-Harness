#!/bin/bash
# =============================================================================
# Zero-Omission-Harness Pre-Commit Hook
# Tự động chạy validation trước mỗi commit
# =============================================================================

set -e

echo "🔍 Running Zero-Omission-Harness pre-commit validation..."

# Kiểm tra zoh CLI
if command -v zoh &> /dev/null; then
    CLI="zoh"
elif [ -f ".agent/consistency/cli.py" ]; then
    CLI="python .agent/consistency/cli.py"
else
    echo "❌ ZOH CLI not found. Skip validation."
    echo "   Cài đặt: pip install -e ."
    exit 0
fi

# Chạy consistency check
echo "   → Running validation..."
if $CLI validate --quiet; then
    echo "✅ Validation passed"
else
    echo ""
    echo "❌ VALIDATION FAILED"
    echo ""
    echo "Các file chưa đồng bộ. Vui lòng chạy:"
    echo "   $CLI validate"
    echo ""
    echo "Hoặc xem chi tiết lỗi:"
    echo "   cat .agent/consistency/reports/consistency_*.md"
    echo ""
    exit 1
fi

# Kiểm tra state consistency
if $CLI check-consistency --detailed; then
    echo "✅ State consistency check passed"
else
    echo ""
    echo "⚠️  State consistency issues detected"
    exit 1
fi

echo ""
echo "✅ Pre-commit checks passed. Proceeding with commit..."
echo ""

exit 0
